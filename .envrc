# Activate the Guix environment defined in manifest.scm.
# direnv re-evaluates this file whenever manifest.scm changes.
use guix

# monklib is a C++/CMake/pybind11 extension not packaged in Guix.
# We clone it with --recurse-submodules (pybind11 is a bundled submodule)
# and build it into a local venv using the venv's own ensurepip-bundled pip
# (not Guix's python3 -m pip, which has a broken resolvelib).

MONKLIB_COMMIT="6fc6c25b36c04af122d0b44a4a9df6921910fba7"
MONKLIB_SRC="$PWD/.monklib-src"
VENV="$PWD/.venv"
PYVER=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
MONKLIB_SITEPKG="$VENV/lib/python${PYVER}/site-packages"

if [ ! -d "$MONKLIB_SRC" ]; then
    log_status "Cloning monklib (with pybind11 submodule)..."
    git clone --quiet --recurse-submodules \
        https://github.com/MONK-system/library.git "$MONKLIB_SRC"
    git -C "$MONKLIB_SRC" checkout --quiet "$MONKLIB_COMMIT"
fi

if [ ! -d "$VENV" ]; then
    log_status "Creating virtualenv..."
    # Plain venv (no --system-site-packages) so ensurepip's bundled pip is
    # used, not the user-profile pip which has a broken resolvelib.
    python3 -m venv "$VENV"
fi

if ! ls "$MONKLIB_SITEPKG"/monklib*.so 2>/dev/null | grep -q .; then
    log_status "Building and installing monklib..."
    # --no-build-isolation: use Guix's cmake/ninja instead of pip downloading
    # its own cmake Python wrapper (which has no bundled binary on Guix).
    "$VENV/bin/pip" install --quiet --no-build-isolation "$MONKLIB_SRC"
fi

# Expose the venv (for monklib) and Guix packages (for Django, numpy, etc.).
# GUIX_PYTHONPATH is set by `use guix` but not processed when VIRTUAL_ENV is
# active, so we merge it into PYTHONPATH explicitly.
export VIRTUAL_ENV="$VENV"
PATH_add "$VENV/bin"
export PYTHONPATH="$MONKLIB_SITEPKG${GUIX_PYTHONPATH:+:$GUIX_PYTHONPATH}"
